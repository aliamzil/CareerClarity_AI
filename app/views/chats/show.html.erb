
<%= @chat.persona %>

<div class="container">
  <h1 class="text-center"><%= @chat.persona %></h1>

  <div class="messages-container">
    <% @messages.each do |message| %>
      <div class="message <%= message.role %>">
        <p><%= message.content %></p>
      </div>
    <% end %>
  </div>

  <%= simple_form_for [@chat, @message] do |f| %>
    <%= f.input :content, label: false, placeholder: "Votre message...", input_html: { rows: 3 } %>
    <%= f.submit "Envoyer", class: "btn main-button mt-2" %>
  <% end %>

  <%= link_to "Voir mon bilan", chat_result_path(@chat), class: "btn btn-success mt-3" %>
  <%= link_to "Retourner à l'historique", chats_path, class: "btn main-button mt-3" %>
</div>

<%= link_to "Retourner à l'historique", chats_path, class: "btn main-button mt-2" %>
<%= link_to "Page d'accueil", root_path, class: "btn main-button mt-2" %>
