<h1>Ici le Bilan de la conversation avec des conseils étape par étape</h1>
<div class="container mt-5 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <div class="text-center mb-5">
        <span class="badge bg-primary mb-2">Bilan CareerClarity AI</span>
        <h1 class="display-4"><%= @chat.title %></h1>
        <p class="text-muted">Généré pour votre profil : <strong><%= @chat.persona %></strong></p>
      </div>

      <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-5">
          <div class="roadmap-content">
            <%# On utilise simple_format pour garder les sauts de ligne de l'IA %>
            <%= simple_format(@result.roadmap) %>
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center bg-light p-4 rounded-4 shadow-sm">
        <div>
          <%= link_to chats_path, class: "btn btn-outline-secondary" do %>
            <i class="fas fa-arrow-left"></i> Mes conversations
          <% end %>
        </div>

        <div class="text-end">
          <button class="btn btn-dark" onclick="window.print()">
            <i class="fas fa-print"></i> Imprimer mon plan
          </button>
          <%= link_to "Nouvelle simulation", root_path, class: "btn btn-primary" %>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* Un peu de style pour rendre la roadmap lisible */
  .roadmap-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #2d3436;
  }
  .roadmap-content h2, .roadmap-content h3 {
    color: #0d6efd;
    margin-top: 1.5rem;
  }
</style>

<%= link_to "Retourner à la Page d'accueil", root_path, class:"btn histo-button mt-3" %>
